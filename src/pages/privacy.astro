---
import { links } from '../config/links.ts';
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Privacy Policy — AroDeploy</title>
    <meta name="description" content="AroDeploy privacy policy. How we collect, use, and protect your data." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        var t = localStorage.getItem('arodeploy-theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root,
      html[data-theme="dark"] {
        --bg:              #0a0a0a;
        --surface:         #111111;
        --border:          #1f1f1f;
        --border-strong:   #2e2e2e;
        --text:            #f5f5f5;
        --text-secondary:  #b0b0b0;
        --text-muted:      #7a7a7a;
        --nav-bg:          rgba(10, 10, 10, 0.92);
        --btn-hover:       #d0d0d0;
      }

      @media (prefers-color-scheme: light) {
        :root:not([data-theme="dark"]) {
          --bg:              #f5f5f5;
          --surface:         #ffffff;
          --border:          #e0e0e0;
          --border-strong:   #c8c8c8;
          --text:            #0a0a0a;
          --text-secondary:  #555555;
          --text-muted:      #999999;
          --nav-bg:          rgba(245, 245, 245, 0.92);
          --btn-hover:       #1f1f1f;
        }
      }
      html[data-theme="light"] {
        --bg:              #f5f5f5;
        --surface:         #ffffff;
        --border:          #e0e0e0;
        --border-strong:   #c8c8c8;
        --text:            #0a0a0a;
        --text-secondary:  #555555;
        --text-muted:      #999999;
        --nav-bg:          rgba(245, 245, 245, 0.92);
        --btn-hover:       #1f1f1f;
      }

      html {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        font-size: 16px;
        line-height: 1.6;
        scrollbar-width: none;
      }
      html::-webkit-scrollbar { display: none; }

      body { min-height: 100vh; }
      a { color: inherit; text-decoration: none; }

      nav {
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 clamp(1.5rem, 5vw, 4rem);
        height: 60px;
        background: var(--nav-bg);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }

      .nav-logo {
        font-size: 0.8125rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text);
      }

      .nav-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.45rem 1rem;
        font-size: 0.8125rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        border: 1px solid var(--border-strong);
        color: var(--text-secondary);
        background: transparent;
        transition: border-color 0.15s, color 0.15s;
        cursor: pointer;
      }
      .nav-cta:hover { border-color: var(--text-secondary); color: var(--text); }

      .nav-right {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }
      .theme-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: transparent;
        border: 1px solid var(--border-strong);
        color: var(--text-muted);
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
        padding: 0;
      }
      .theme-toggle:hover {
        border-color: var(--text-secondary);
        color: var(--text-secondary);
      }
      .theme-toggle .icon-sun,
      .theme-toggle .icon-moon { display: none; }
      html[data-theme="dark"] .theme-toggle .icon-sun { display: block; }
      html[data-theme="light"] .theme-toggle .icon-moon { display: block; }
      html:not([data-theme]) .theme-toggle .icon-sun { display: none; }
      html:not([data-theme]) .theme-toggle .icon-moon { display: none; }
      @media (prefers-color-scheme: dark) {
        html:not([data-theme]) .theme-toggle .icon-sun { display: block; }
      }
      @media (prefers-color-scheme: light) {
        html:not([data-theme]) .theme-toggle .icon-moon { display: block; }
      }

      .content {
        max-width: 680px;
        margin: 0 auto;
        padding: clamp(3rem, 8vw, 6rem) clamp(1.5rem, 5vw, 4rem);
      }

      .content h1 {
        font-size: clamp(1.5rem, 3vw, 2.25rem);
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.2;
        margin-bottom: 0.5rem;
      }

      .last-updated {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 3rem;
      }

      .content h2 {
        font-size: 1.0625rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text);
        margin-top: 2.5rem;
        margin-bottom: 0.75rem;
      }

      .content p {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.75;
        margin-bottom: 1rem;
      }

      .content ul {
        list-style: none;
        padding: 0;
        margin-bottom: 1rem;
      }

      .content li {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.75;
        padding-left: 1rem;
        position: relative;
      }
      .content li::before {
        content: "—";
        position: absolute;
        left: 0;
        color: var(--text-muted);
      }

      .content strong { color: var(--text); font-weight: 600; }

      .content a {
        color: var(--text);
        text-decoration: underline;
        text-underline-offset: 0.15em;
      }
      .content a:hover { color: var(--text-secondary); }

      footer {
        padding: 1.75rem clamp(1.5rem, 5vw, 4rem);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        border-top: 1px solid var(--border);
        flex-wrap: wrap;
      }

      .footer-copy {
        font-size: 0.75rem;
        color: var(--text-muted);
      }

      .footer-link {
        font-size: 0.8125rem;
        color: var(--text-muted);
        transition: color 0.15s;
      }
      .footer-link:hover { color: var(--text-secondary); }

      .footer-links {
        display: flex;
        gap: 1.25rem;
        flex-wrap: wrap;
      }
    </style>
  </head>
  <body>

    <nav>
      <a href="/" class="nav-logo">AroDeploy</a>
      <div class="nav-right">
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
          <svg class="icon-sun" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.3"/>
            <path d="M8 1.5v1.5M8 13v1.5M1.5 8H3M13 8h1.5M3.17 3.17l1.06 1.06M11.77 11.77l1.06 1.06M3.17 12.83l1.06-1.06M11.77 4.23l1.06-1.06" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          <svg class="icon-moon" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M13.36 10.06A5.5 5.5 0 015.94 2.64a6 6 0 107.42 7.42z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <a href={links.console} class="nav-cta">
          Open Console
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.25" stroke-linecap="square"/>
          </svg>
        </a>
      </div>
    </nav>

    <main class="content">
      <h1>Privacy Policy</h1>
      <p class="last-updated">Last updated: 17 March 2026</p>

      <h2>Who we are</h2>
      <p>
        AroDeploy is operated by AroDeploy ("we", "us", "our"). We provide a deployment platform for developers, running on global infrastructure (Hetzner). Our services are accessible at <a href={links.site}>arodeploy.com</a> and <a href={links.console}>console.arodeploy.com</a>.
      </p>

      <h2>What data we collect</h2>
      <p>When you use AroDeploy, we may collect:</p>
      <ul>
        <li><strong>Account information</strong> — email address, name, and password hash when you sign up.</li>
        <li><strong>Billing information</strong> — payment details are processed by our payment provider (Stripe). We do not store card numbers.</li>
        <li><strong>Usage data</strong> — resource consumption (CPU, memory, bandwidth, storage) to calculate billing and provide dashboards.</li>
        <li><strong>Application data</strong> — source code, container images, and environment variables you deploy. These are stored encrypted and are never shared.</li>
        <li><strong>Log data</strong> — server access logs, error logs, and deployment logs to provide debugging tools and maintain service reliability.</li>
      </ul>

      <h2>How we use your data</h2>
      <ul>
        <li>To provide and maintain the AroDeploy platform.</li>
        <li>To process payments and manage your subscription.</li>
        <li>To send transactional emails (deploy notifications, billing receipts, security alerts).</li>
        <li>To monitor service health and investigate incidents.</li>
        <li>To improve the platform based on aggregate usage patterns.</li>
      </ul>
      <p>We do <strong>not</strong> sell your data. We do <strong>not</strong> use your data for advertising. We do <strong>not</strong> share your data with third parties except as needed to operate the service (payment processing, infrastructure providers).</p>

      <h2>Where your data is stored</h2>
      <p>
        Infrastructure runs on Hetzner servers in <strong>Germany, Finland, US East, US West, and Singapore</strong>. You choose your deployment region when creating a project. If you select an EU region (Germany or Finland), your application data stays within the European Union. Account data (email, billing) is always processed within the EU regardless of your chosen deployment region.
      </p>

      <h2>Data retention</h2>
      <p>
        We retain your account data for as long as your account is active. When you delete your account, we remove your personal data within 30 days. Deployment artifacts (container images, volumes) are deleted immediately upon project deletion. Billing records may be retained for up to 7 years as required by tax law.
      </p>

      <h2>Your rights (GDPR)</h2>
      <p>If you are in the EU/EEA, you have the right to:</p>
      <ul>
        <li><strong>Access</strong> — request a copy of the personal data we hold about you.</li>
        <li><strong>Rectification</strong> — correct inaccurate personal data.</li>
        <li><strong>Erasure</strong> — request deletion of your personal data.</li>
        <li><strong>Portability</strong> — receive your data in a structured, machine-readable format.</li>
        <li><strong>Objection</strong> — object to processing of your data for specific purposes.</li>
        <li><strong>Restriction</strong> — request restricted processing of your data.</li>
      </ul>
      <p>To exercise any of these rights, email <a href="mailto:privacy@arodeploy.com">privacy@arodeploy.com</a>.</p>

      <h2>Cookies</h2>
      <p>
        We use only essential cookies required to maintain your session and authentication state. We do not use tracking cookies, analytics cookies, or third-party advertising cookies. The marketing site (arodeploy.com) does not set any cookies.
      </p>

      <h2>Third-party services</h2>
      <ul>
        <li><strong>Hetzner</strong> — infrastructure provider (Germany, Finland, US East, US West, Singapore). <a href="https://www.hetzner.com/legal/privacy-policy">Their privacy policy</a>.</li>
        <li><strong>Stripe</strong> — payment processing. <a href="https://stripe.com/privacy">Their privacy policy</a>.</li>
      </ul>

      <h2>Changes to this policy</h2>
      <p>
        We may update this policy from time to time. When we make material changes, we will notify you by email or through the console. The "last updated" date at the top reflects the most recent revision.
      </p>

      <h2>Contact</h2>
      <p>
        For privacy-related questions or requests, email <a href="mailto:privacy@arodeploy.com">privacy@arodeploy.com</a>.
      </p>
    </main>

    <footer>
      <span class="footer-copy">&copy; {year} AroDeploy. All rights reserved.</span>
      <div class="footer-links">
        <a href="/" class="footer-link">Home</a>
        <!-- <a href={links.docs} class="footer-link">Docs</a> -->
        <a href={links.console} class="footer-link">Console</a>
      </div>
    </footer>

    <script>
      (() => {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', () => {
          const html = document.documentElement;
          const current = html.getAttribute('data-theme');
          let next;
          if (!current) {
            next = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'light' : 'dark';
          } else {
            next = current === 'dark' ? 'light' : 'dark';
          }
          html.setAttribute('data-theme', next);
          localStorage.setItem('arodeploy-theme', next);
        });
      })();
    </script>

  </body>
</html>
