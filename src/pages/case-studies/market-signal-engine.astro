    <script>
      (() => {
        /* Pipeline phases on the left drive flowchart stages on the right */
        const phases = document.querySelectorAll('.pipeline-phase');
        const stages = document.querySelectorAll('.fc-stage');
        const output = document.querySelector('.fc-output');
        if (!phases.length || !stages.length) return;

        let highestRevealed = -1;

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            const idx = Number(entry.target.dataset.phase);
            if (entry.isIntersecting && idx > highestRevealed) {
              highestRevealed = idx;
            }
          });

          /* Reveal all stages up to the highest visible phase */
          stages.forEach(s => {
            const si = Number(s.dataset.stage);
            if (si <= highestRevealed + 1) {        /* +1 because phases are 0-indexed */
              s.classList.add('visible');
            }
            s.classList.toggle('active', si === highestRevealed + 1);
          });

          /* Show output (stage 6) once last phase scrolls in */
          if (highestRevealed >= phases.length - 1) {
            const outStage = document.querySelector('.fc-stage[data-stage="6"]');
            if (outStage) outStage.classList.add('visible');
          }
        }, {
          threshold: 0.3,
          rootMargin: '0px 0px -15% 0px'
        });

        phases.forEach(p => observer.observe(p));

        /* Reveal stage 1 immediately so the panel isn't empty on load */
        requestAnimationFrame(() => {
          if (stages[0]) stages[0].classList.add('visible', 'active');
          highestRevealed = 0;
        });
      })();

      /* ── Theme toggle ── */
      (() => {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', () => {
          const html = document.documentElement;
          const current = html.getAttribute('data-theme');
          let next;
          if (!current) {
            next = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'light' : 'dark';
          } else {
            next = current === 'dark' ? 'light' : 'dark';
          }
          html.setAttribute('data-theme', next);
          localStorage.setItem('arodeploy-theme', next);
        });
      })();
    </script>

