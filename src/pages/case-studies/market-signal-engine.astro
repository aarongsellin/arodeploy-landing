---
import { links } from '../../config/links.ts';
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>Market Signal Engine — AroDeploy Case Study</title>
    <meta name="description" content="How a semantic market intelligence system uses embedding pipelines, LLM-powered signal extraction, and a continuous optimization loop to surface product opportunities." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script is:inline>
      (function() {
        var t = localStorage.getItem('arodeploy-theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root,
      html[data-theme="dark"] {
        --bg:              #0a0a0a;
        --surface:         #111111;
        --surface-2:       #171717;
        --border:          #1f1f1f;
        --border-strong:   #2e2e2e;
        --text:            #f5f5f5;
        --text-secondary:  #b0b0b0;
        --text-muted:      #7a7a7a;
        --nav-bg:          rgba(10, 10, 10, 0.92);
        --btn-hover:       #d0d0d0;
        --row-shadow:      0 6px 14px rgba(0,0,0,0.45), 0 -6px 14px rgba(0,0,0,0.45);
      }

      @media (prefers-color-scheme: light) {
        :root:not([data-theme="dark"]) {
          --bg:              #f5f5f5;
          --surface:         #ffffff;
          --surface-2:       #ebebeb;
          --border:          #e0e0e0;
          --border-strong:   #c8c8c8;
          --text:            #0a0a0a;
          --text-secondary:  #555555;
          --text-muted:      #999999;
          --nav-bg:          rgba(245, 245, 245, 0.92);
          --btn-hover:       #1f1f1f;
          --row-shadow:      0 6px 14px rgba(0,0,0,0.1), 0 -6px 14px rgba(0,0,0,0.1);
        }
      }
      html[data-theme="light"] {
        --bg:              #f5f5f5;
        --surface:         #ffffff;
        --surface-2:       #ebebeb;
        --border:          #e0e0e0;
        --border-strong:   #c8c8c8;
        --text:            #0a0a0a;
        --text-secondary:  #555555;
        --text-muted:      #999999;
        --nav-bg:          rgba(245, 245, 245, 0.92);
        --btn-hover:       #1f1f1f;
        --row-shadow:      0 6px 14px rgba(0,0,0,0.1), 0 -6px 14px rgba(0,0,0,0.1);
      }

      html {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        font-size: 16px;
        line-height: 1.6;
        scrollbar-width: none;
      }
      html::-webkit-scrollbar { display: none; }

      body { min-height: 100vh; }
      a { color: inherit; text-decoration: none; }

      /* ── NAV ── */
      nav {
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 clamp(1.5rem, 5vw, 4rem);
        height: 60px;
        background: var(--nav-bg);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }

      .nav-left {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }

      .nav-logo {
        font-size: 0.8125rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text);
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 0.125rem;
      }

      .nav-link {
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text-muted);
        padding: 0.25rem 0.625rem;
        transition: color 0.15s;
        letter-spacing: 0.02em;
      }
      .nav-link:hover { color: var(--text-secondary); }

      .nav-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.45rem 1rem;
        font-size: 0.8125rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        border: 1px solid var(--border-strong);
        color: var(--text-secondary);
        background: transparent;
        transition: border-color 0.15s, color 0.15s;
        cursor: pointer;
      }
      .nav-cta:hover { border-color: var(--text-secondary); color: var(--text); }

      .nav-right {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .theme-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: transparent;
        border: 1px solid var(--border-strong);
        color: var(--text-muted);
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
        padding: 0;
      }
      .theme-toggle:hover {
        border-color: var(--text-secondary);
        color: var(--text-secondary);
      }
      .theme-toggle .icon-sun,
      .theme-toggle .icon-moon { display: none; }
      html[data-theme="dark"] .theme-toggle .icon-sun { display: block; }
      html[data-theme="light"] .theme-toggle .icon-moon { display: block; }
      html:not([data-theme]) .theme-toggle .icon-sun { display: none; }
      html:not([data-theme]) .theme-toggle .icon-moon { display: none; }
      @media (prefers-color-scheme: dark) {
        html:not([data-theme]) .theme-toggle .icon-sun { display: block; }
      }
      @media (prefers-color-scheme: light) {
        html:not([data-theme]) .theme-toggle .icon-moon { display: block; }
      }

      /* ── BREADCRUMB ── */
      .breadcrumb {
        padding: 0.875rem clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8rem;
        color: var(--text-muted);
      }

      .breadcrumb a {
        color: var(--text-muted);
        transition: color 0.15s;
        display: flex;
        align-items: center;
        gap: 0.35rem;
      }
      .breadcrumb a:hover { color: var(--text-secondary); }
      .breadcrumb-sep { color: var(--border-strong); }
      .breadcrumb-current { color: var(--text-secondary); }

      /* ── HERO ── */
      .hero {
        padding: clamp(3.5rem, 9vw, 7rem) clamp(1.5rem, 5vw, 4rem) clamp(3rem, 8vw, 6rem);
        border-bottom: 1px solid var(--border);
        max-width: 760px;
      }

      .eyebrow {
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 1.25rem;
      }

      .hero h1 {
        font-size: clamp(2rem, 5vw, 3.25rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.1;
        color: var(--text);
        margin-bottom: 1.25rem;
      }

      .hero-desc {
        font-size: clamp(0.9375rem, 1.5vw, 1.0625rem);
        color: var(--text-secondary);
        line-height: 1.75;
        max-width: 580px;
      }

      /* ── SECTION SHARED ── */
      .section {
        padding: clamp(3rem, 7vw, 5.5rem) clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
        max-width: 860px;
      }

      .section-label {
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
      }

      .section h2 {
        font-size: clamp(1.25rem, 2.5vw, 1.75rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        color: var(--text);
        margin-bottom: 1.25rem;
        line-height: 1.2;
      }

      .section p {
        font-size: 0.9375rem;
        color: var(--text-secondary);
        line-height: 1.75;
        margin-bottom: 1rem;
      }
      .section p:last-child { margin-bottom: 0; }

      /* ── PIPELINE STEPS ── */
      .pipeline {
        display: flex;
        flex-direction: column;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        margin-top: 2rem;
      }

      .pipeline-phase {
        background: var(--bg);
      }

      .phase-header {
        display: grid;
        grid-template-columns: 3rem 1fr;
        cursor: default;
      }

      .phase-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--text-muted);
        padding: 1.25rem 0 1.25rem 1.25rem;
        align-self: start;
        padding-top: 1.35rem;
      }

      .phase-content {
        padding: 1.25rem 1.5rem;
        border-left: 1px solid var(--border);
      }

      .phase-content h3 {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--text);
        margin-bottom: 0.75rem;
      }

      .phase-content p {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.65;
        margin-bottom: 0.75rem;
      }
      .phase-content p:last-child { margin-bottom: 0; }

      .phase-items {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        margin-top: 0.5rem;
      }

      .phase-items li {
        font-size: 0.825rem;
        color: var(--text-secondary);
        line-height: 1.5;
        display: flex;
        align-items: baseline;
        gap: 0.6rem;
      }

      .phase-items li::before {
        content: '—';
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.7rem;
        color: var(--text-muted);
        flex-shrink: 0;
      }

      .pipeline-phase:hover { background: var(--surface); }

      /* ── CAPABILITY CARDS ── */
      .capability-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        margin-top: 2rem;
      }

      .capability-card {
        background: var(--bg);
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        transition: background 0.15s;
      }
      .capability-card:hover { background: var(--surface); }

      .capability-card h3 {
        font-size: 0.9375rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text);
      }

      .capability-card p {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.65;
      }

      .inline-code {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.82em;
        color: var(--text);
        background: var(--surface-2);
        border: 1px solid var(--border);
        padding: 0.1em 0.35em;
        border-radius: 2px;
        white-space: nowrap;
      }

      /* ── ARCH TABLE ── */
      .arch-table-wrap { overflow-x: auto; max-width: 860px; margin-top: 2rem; }

      .arch-table {
        width: 100%;
        border-collapse: collapse;
        border: 1px solid var(--border);
      }

      .arch-table th,
      .arch-table td {
        padding: 0.65rem 1.25rem;
        text-align: left;
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
      }

      .arch-table thead th {
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-muted);
        background: var(--surface);
      }

      .arch-table td:first-child {
        font-size: 0.8rem;
        color: var(--text-secondary);
        width: 35%;
        background: var(--bg);
      }

      .arch-table td:not(:first-child) {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        color: var(--text);
        background: var(--bg);
      }

      .arch-table tbody tr:last-child td { border-bottom: none; }
      .arch-table tbody tr { transition: background 0.15s; }
      .arch-table tbody tr:hover td {
        background: var(--surface-2);
        box-shadow: var(--row-shadow);
      }

      /* ── FOOTER ── */
      footer {
        padding: 1.75rem clamp(1.5rem, 5vw, 4rem);
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: start;
        gap: 1rem 2rem;
      }

      .footer-left {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
      }

      .footer-eu {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8rem;
        color: var(--text-secondary);
        font-weight: 500;
      }
      .footer-eu svg { flex-shrink: 0; }

      .footer-copy {
        font-size: 0.75rem;
        color: var(--text-muted);
      }

      .footer-link {
        font-size: 0.8125rem;
        color: var(--text-muted);
        transition: color 0.15s;
        align-self: center;
      }
      .footer-link:hover { color: var(--text-secondary); }

      /* ── TWO-COLUMN LAYOUT ── */
      .split-layout {
        display: grid;
        grid-template-columns: 1fr 460px;
        gap: 0;
        border-bottom: 1px solid var(--border);
      }
      .split-content {
        min-width: 0;
      }
      .split-content .section {
        max-width: none;
      }

      .flowchart-panel {
        position: relative;
        border-left: 1px solid var(--border-strong);
        background: var(--surface);
      }

      .flowchart-sticky {
        position: sticky;
        top: 61px;
        padding: 2.5rem 2rem;
        display: flex;
        flex-direction: column;
        gap: 0;
        max-height: calc(100vh - 61px);
        overflow-y: auto;
        scrollbar-width: none;
      }
      .flowchart-sticky::-webkit-scrollbar { display: none; }

      .flowchart-label {
        font-size: 0.6875rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-secondary);
        margin-bottom: 2rem;
      }

      /* ── FLOWCHART NODES ── */
      .fc-stage {
        opacity: 0;
        transform: translateY(14px);
        transition: opacity 0.55s ease, transform 0.55s ease;
      }
      .fc-stage.visible {
        opacity: 1;
        transform: translateY(0);
      }

      .fc-node {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        padding: 1.1rem 1.25rem;
        background: var(--bg);
        border: 1px solid var(--border-strong);
        transition: border-color 0.3s, background 0.3s;
      }
      .fc-stage.active .fc-node {
        border-color: #555;
        background: var(--surface-2);
      }

      .fc-node-header {
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }

      .fc-node-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--text-secondary);
        min-width: 1.5rem;
      }
      .fc-stage.active .fc-node-num { color: var(--text); }

      .fc-node-icon {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
        color: var(--text-secondary);
      }
      .fc-stage.active .fc-node-icon { color: var(--text); }

      .fc-node-title {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--text);
        letter-spacing: -0.01em;
      }

      .fc-node-desc {
        font-size: 0.8125rem;
        color: var(--text-secondary);
        line-height: 1.6;
        padding-left: 0;
      }

      .fc-tech-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.3rem;
        margin-top: 0.1rem;
      }

      .fc-tech {
        font-size: 0.6875rem;
        font-family: 'JetBrains Mono', monospace;
        padding: 0.2rem 0.55rem;
        background: var(--surface);
        border: 1px solid var(--border-strong);
        border-radius: 2px;
        color: var(--text-secondary);
        transition: color 0.3s, border-color 0.3s;
      }
      .fc-stage.active .fc-tech {
        color: var(--text);
        border-color: #555;
      }

      .fc-connector {
        width: 2px;
        height: 20px;
        background: var(--border-strong);
        margin-left: 2.25rem;
        transition: background 0.3s;
      }
      .fc-stage.visible .fc-connector { background: #555; }

      .fc-output {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        padding: 1rem 1.25rem;
        border: 2px dashed #555;
        background: var(--bg);
      }

      .fc-output-icon {
        width: 20px;
        height: 20px;
        flex-shrink: 0;
        color: var(--text-secondary);
      }

      .fc-output-text {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--text);
      }

      .fc-output-sub {
        font-size: 0.75rem;
        color: var(--text-secondary);
        margin-top: 0.1rem;
      }

      /* ── RESPONSIVE ── */
      @media (max-width: 1100px) {
        .split-layout {
          grid-template-columns: 1fr;
        }
        .flowchart-panel { display: none; }
      }
      @media (max-width: 768px) {
        .nav-links { display: none; }
      }
      @media (max-width: 640px) {
        footer { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>

    <nav>
      <div class="nav-left">
        <a href="/" class="nav-logo">AroDeploy</a>
        <div class="nav-links">
          <a href="/#products" class="nav-link">Products</a>
          <a href="/#plans" class="nav-link">Pricing</a>
        </div>
      </div>
      <div class="nav-right">
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
          <svg class="icon-sun" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.3"/>
            <path d="M8 1.5v1.5M8 13v1.5M1.5 8H3M13 8h1.5M3.17 3.17l1.06 1.06M11.77 11.77l1.06 1.06M3.17 12.83l1.06-1.06M11.77 4.23l1.06-1.06" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          <svg class="icon-moon" width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M13.36 10.06A5.5 5.5 0 015.94 2.64a6 6 0 107.42 7.42z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <a href={links.console} class="nav-cta">
          Open Console
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.25" stroke-linecap="square"/>
          </svg>
        </a>
      </div>
    </nav>

    <div class="breadcrumb">
      <a href="/">
        <svg width="11" height="11" viewBox="0 0 11 11" fill="none">
          <path d="M7 9L3 5.5 7 2" stroke="currentColor" stroke-width="1.25" stroke-linecap="square"/>
        </svg>
        Home
      </a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">Case Study</span>
    </div>

    <main>

      <!-- ── HERO ── -->
      <section class="hero">
        <p class="eyebrow">Case Study</p>
        <h1>Market Signal Engine</h1>
        <p class="hero-desc">
          A semantic intelligence system that turns raw reviews, search queries, and product descriptions
          into an optimizable embedding field — surfacing unmet demand, competitive gaps, and positioning
          opportunities through a continuous five-stage pipeline.
        </p>
      </section>

      <!-- ── THE SYSTEM ── -->
      <section class="section">
        <p class="section-label">Overview</p>
        <h2>Turning data into a field you can optimize.</h2>
        <p>
          The core idea is to represent both consumer demand and competitive supply as vectors in the same
          embedding space. When you build that field correctly, the unoccupied regions with high demand density
          become directly interpretable as product opportunities.
        </p>
        <p>
          The pipeline runs in five stages — from raw data ingestion through to human-readable strategy output.
          Each stage is independently replaceable, which is the key architectural property that makes the system
          useful in practice: you can swap the embedding model, change the LLM used for signal extraction, or
          rescore the optimization function without touching the rest of the pipeline.
        </p>
      </section>

      <!-- ── SPLIT LAYOUT: text left, flowchart right ── -->
      <div class="split-layout">
        <div class="split-content">

      <!-- ── PIPELINE ── -->
      <section class="section">
        <p class="section-label">Pipeline</p>
        <h2>Five stages from raw signal to actionable strategy.</h2>
        <div class="pipeline">

          <div class="pipeline-phase" data-phase="0">
            <div class="phase-header">
              <span class="phase-num">01</span>
              <div class="phase-content">
                <h3>Data Layer</h3>
                <p>
                  Scraping runs as short-lived on-demand workers — one container per job, deployed on trigger, exits on completion.
                  <code class="inline-code">Playwright</code> handles JavaScript-rendered pages (Amazon, Google Shopping, review aggregators).
                  Raw text is written to Postgres before any processing so the corpus can be re-embedded without re-scraping.
                  Embedding jobs are queued via <code class="inline-code">BullMQ</code> on Redis and processed by a separate worker pool.
                </p>
                <ul class="phase-items">
                  <li>Scrape reviews — Playwright worker, one container per source, exits after completing the run</li>
                  <li>Scrape search queries — same worker pattern, targets autocomplete APIs and SERP data</li>
                  <li>Scrape product descriptions — competitor listings, category pages, structured data</li>
                  <li>Compute embeddings — BullMQ job per batch, processed by Ollama embedding worker</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="pipeline-phase" data-phase="1">
            <div class="phase-header">
              <span class="phase-num">02</span>
              <div class="phase-content">
                <h3>Signal Extraction</h3>
                <p>
                  Structured signals are extracted by sending batches of raw text to a locally-hosted LLM via
                  <code class="inline-code">Ollama</code>. The default model is <code class="inline-code">llama3.2</code> for extraction tasks —
                  small enough to run without a GPU, accurate enough for structured JSON output with a well-formed prompt.
                  Sentiment scoring uses <code class="inline-code">VADER</code> for speed on short texts, falling back to the LLM
                  for longer or ambiguous reviews. Topic clustering uses <code class="inline-code">HDBSCAN</code> over the existing embeddings.
                </p>
                <ul class="phase-items">
                  <li>Sentiment analysis — VADER for short texts, Ollama llama3.2 for nuanced or long reviews</li>
                  <li>Feature extraction — Ollama structured JSON output, prompt-engineered per product category</li>
                  <li>Topic clustering — HDBSCAN over pgvector embeddings, min_cluster_size tunable from dashboard</li>
                  <li>Dissatisfaction scoring — weighted composite of negative sentiment intensity × feature frequency</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="pipeline-phase" data-phase="2">
            <div class="phase-header">
              <span class="phase-num">03</span>
              <div class="phase-content">
                <h3>Field Construction</h3>
                <p>
                  The embedding space is high-dimensional (1024–3072 dims depending on model), so fields are computed
                  over a 2D UMAP projection for performance, with the mapping stored so sample points can be unprojected
                  back to the original space for KNN lookups. KDE is computed with
                  <code class="inline-code">scipy.stats.gaussian_kde</code>; both fields are evaluated on the same
                  grid and the ratio is computed element-wise in <code class="inline-code">numpy</code>.
                </p>
                <ul class="phase-items">
                  <li>UMAP projection — dimensionality reduction before KDE, projection stored for inversion</li>
                  <li>Demand field — scipy gaussian_kde over projected review + query embeddings, weights = dissatisfaction scores</li>
                  <li>Competition field — scipy gaussian_kde over projected product description embeddings</li>
                  <li>F(x) = demand_kde(x) / (competition_kde(x) + ε), evaluated on a 200×200 numpy grid</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="pipeline-phase" data-phase="3">
            <div class="phase-header">
              <span class="phase-num">04</span>
              <div class="phase-content">
                <h3>Optimization</h3>
                <p>
                  Peaks in the F(x) grid are found with <code class="inline-code">scipy.ndimage.maximum_filter</code> — local maxima
                  above a configurable percentile threshold. Each peak is a 2D point in the UMAP projection;
                  it is inverted back to the original embedding space and passed to
                  <code class="inline-code">pgvector</code>'s <code class="inline-code">&lt;-&gt;</code> (L2) or
                  <code class="inline-code">&lt;=&gt;</code> (cosine) operator to retrieve the nearest real documents.
                </p>
                <ul class="phase-items">
                  <li>Peak detection — scipy maximum_filter over the F(x) grid, threshold from dashboard slider</li>
                  <li>Inversion — UMAP inverse_transform to recover original-space coordinates per peak</li>
                  <li>KNN retrieval — pgvector cosine search, top-20 reviews + top-10 queries per peak</li>
                  <li>Descriptor assembly — retrieved texts + feature tags bundled as structured context per region</li>
                </ul>
              </div>
            </div>
          </div>

          <div class="pipeline-phase" data-phase="4">
            <div class="phase-header">
              <span class="phase-num">05</span>
              <div class="phase-content">
                <h3>Interpretation</h3>
                <p>
                  Each opportunity region's context bundle is sent to <code class="inline-code">Ollama</code> running
                  <code class="inline-code">llama3.1:70b</code> (or <code class="inline-code">gpt-4o</code> via the OpenAI API if configured)
                  with a structured output prompt enforcing a JSON schema. The larger model is used here deliberately —
                  this is the stage where reasoning quality matters most. The response is validated with
                  <code class="inline-code">Pydantic</code> and stored in Postgres alongside the run record.
                </p>
                <ul class="phase-items">
                  <li>Feature suggestions — LLM maps complaint clusters to concrete capability gaps</li>
                  <li>Positioning language — verbatim review phrases recast as product copy angles</li>
                  <li>Pricing band — inferred from price-mention frequency and complaint intensity at different tiers</li>
                  <li>Marketing strategy — channel and messaging recommendations grounded in the source signal cluster</li>
                </ul>
              </div>
            </div>
          </div>

        </div>
      </section>

      <!-- ── SYSTEM DESIGN ── -->
      <section class="section">
        <p class="section-label">System Design</p>
        <h2>Built to be swapped out, not locked in.</h2>
        <p>
          The most important property of the system is that every model is a plug. When you want to
          test a new embedding model — say, switching from OpenAI <code style="font-family:'JetBrains Mono',monospace;font-size:0.85em;color:var(--text)">text-embedding-3-large</code> to
          a locally-hosted <code style="font-family:'JetBrains Mono',monospace;font-size:0.85em;color:var(--text)">nomic-embed-text</code>
          — you should not need to re-scrape, re-extract signals, or rewrite the field construction logic.
        </p>
        <p>
          To support this, the system is designed around a few concrete rules: raw text is always stored
          before it is embedded; embeddings are stored in a versioned table keyed to the model that produced
          them; old embeddings are moved to cold storage when a new model is promoted, not deleted.
          This means you can compare results across models on identical corpora.
        </p>
        <div class="capability-grid">
          <div class="capability-card">
            <h3>Model Switcher</h3>
            <p>
              The management dashboard exposes a dropdown to select the active embedding model and the
              active LLM for signal extraction and interpretation. Switching a model triggers a background
              re-embedding job; the previous model's output remains queryable in cold store until explicitly
              purged.
            </p>
          </div>
          <div class="capability-card">
            <h3>Cold Storage for Embeddings</h3>
            <p>
              When a new embedding model is activated, existing vectors are moved to a cold-store table.
              They are no longer included in field construction by default but can be promoted back at any
              time, enabling A/B comparison between model outputs on the same downstream task.
            </p>
          </div>
          <div class="capability-card">
            <h3>Raw Review Archive</h3>
            <p>
              Every ingested review and search query is stored as raw text before any processing.
              This archive is the source of truth — embeddings are derived artifacts, not the data itself.
              Storing raw inputs means the entire pipeline can be replayed from scratch against a new model
              without re-scraping.
            </p>
          </div>
          <div class="capability-card">
            <h3>Versioned Pipeline Runs</h3>
            <p>
              Each full pipeline execution is recorded with a run ID, the active model configuration,
              and a snapshot of the top-N opportunity regions it produced. This makes it possible to
              diff two runs and see exactly which opportunities appeared, disappeared, or shifted score
              when a model was changed.
            </p>
          </div>
        </div>
      </section>

      <!-- ── WORKERS & ELASTICITY ── -->
      <section class="section">
        <p class="section-label">Workers &amp; Elasticity</p>
        <h2>On-demand containers, not idle services.</h2>
        <p>
          CPU-heavy pipeline stages run as short-lived worker containers deployed on demand by AroDeploy.
          Rather than keeping an always-on pool of workers, each job triggers a container start, processes its
          batch, writes results to Postgres, and exits. This keeps compute costs proportional to actual work —
          not to uptime.
        </p>
        <p>
          <code class="inline-code">BullMQ</code> on Redis acts as the job queue. The management dashboard and the
          scraper scheduler both push jobs onto named queues. AroDeploy's deploy API is called by a thin
          orchestrator service to start the appropriate worker image for each queue. Workers pick up their job
          from the queue on startup and self-terminate on completion or on unrecoverable failure.
        </p>
        <div class="capability-grid">
          <div class="capability-card">
            <h3>Scraper Workers</h3>
            <p>
              Deployed per scrape run. The worker image bundles <code class="inline-code">Playwright</code> with
              Chromium and a thin Python scraping layer. One container per source domain — they run in parallel,
              write raw text to the <code class="inline-code">raw_documents</code> Postgres table, and exit.
            </p>
          </div>
          <div class="capability-card">
            <h3>Embedding Workers</h3>
            <p>
              Triggered whenever new raw documents exist without embeddings for the active model.
              The worker calls <code class="inline-code">Ollama</code> (running as a persistent service on a
              separate container) with batches of text, writes the resulting vectors to
              <code class="inline-code">pgvector</code>, and exits when the queue is drained.
            </p>
          </div>
          <div class="capability-card">
            <h3>Field &amp; Optimization Workers</h3>
            <p>
              Run the full stages 03–04 pipeline: UMAP projection, scipy KDE, F(x) computation, peak detection,
              and pgvector KNN retrieval. Triggered manually from the dashboard or on a schedule after a
              new embedding run completes. Results are stored in a <code class="inline-code">pipeline_runs</code> table.
            </p>
          </div>
          <div class="capability-card">
            <h3>Interpreter Workers</h3>
            <p>
              Receive the opportunity bundle from a completed optimization run, call
              <code class="inline-code">Ollama llama3.1:70b</code> or the OpenAI API, validate the response
              with <code class="inline-code">Pydantic</code>, and write structured results back to Postgres.
              Run time is dominated by LLM inference — no GPU required for the 8B/70B GGUF builds on Ollama.
            </p>
          </div>
        </div>
      </section>

