---
import { links } from '../config/links.ts';
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>AroDeploy — Deploy from git. Simple pricing.</title>
    <meta name="description" content="AroDeploy is a deployment platform with zero-downtime releases, preview environments, and smart builds — servers in the US, Europe, and Singapore with transparent, fixed pricing." />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="AroDeploy — Deploy from git. Simple pricing." />
    <meta property="og:description" content="Zero-downtime releases, preview environments, and smart builds — servers in US, Europe, and Singapore. Plans from €0." />
    <meta property="og:url" content={links.site} />
    <meta property="og:site_name" content="AroDeploy" />
    <meta property="og:image" content={`${links.site}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="AroDeploy — Deploy from git. Simple pricing." />
    <meta name="twitter:description" content="Zero-downtime releases, preview environments, and smart builds — servers in the US, Europe, and Singapore. Plans from €0." />
    <meta name="twitter:image" content={`${links.site}/og-image.png`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <script is:inline>
      /* Apply saved theme before first paint to prevent flash */
      (function() {
        var t = localStorage.getItem('arodeploy-theme');
        if (t) document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      /* ── COLOR TOKENS: DARK (default) ── */
      :root,
      html[data-theme="dark"] {
        --bg:              #0a0a0a;
        --surface:         #111111;
        --surface-2:       #171717;
        --border:          #1f1f1f;
        --border-strong:   #2e2e2e;
        --text:            #f5f5f5;
        --text-secondary:  #b0b0b0;
        --text-muted:      #7a7a7a;
        --nav-bg:          rgba(10, 10, 10, 0.92);
        --btn-hover:       #d0d0d0;
        --savings-bg:      #0d1f0d;
        --savings-border:  #1a3a1a;
        --savings-text:    #6dc46d;
        --tag-bg:          #1a1a1a;
        --tag-text:        #555555;
        --row-shadow:      0 6px 14px rgba(0,0,0,0.45), 0 -6px 14px rgba(0,0,0,0.45);
      }

      /* ── COLOR TOKENS: LIGHT ── */
      @media (prefers-color-scheme: light) {
        :root:not([data-theme="dark"]) {
          --bg:              #f5f5f5;
          --surface:         #ffffff;
          --surface-2:       #ebebeb;
          --border:          #e0e0e0;
          --border-strong:   #c8c8c8;
          --text:            #0a0a0a;
          --text-secondary:  #555555;
          --text-muted:      #999999;
          --nav-bg:          rgba(245, 245, 245, 0.92);
          --btn-hover:       #1f1f1f;
          --savings-bg:      #f0fff4;
          --savings-border:  #a8d8b0;
          --savings-text:    #1a6a28;
          --tag-bg:          #e8e8e8;
          --tag-text:        #888888;
          --row-shadow:      0 6px 14px rgba(0,0,0,0.1), 0 -6px 14px rgba(0,0,0,0.1);
        }
      }
      html[data-theme="light"] {
        --bg:              #f5f5f5;
        --surface:         #ffffff;
        --surface-2:       #ebebeb;
        --border:          #e0e0e0;
        --border-strong:   #c8c8c8;
        --text:            #0a0a0a;
        --text-secondary:  #555555;
        --text-muted:      #999999;
        --nav-bg:          rgba(245, 245, 245, 0.92);
        --btn-hover:       #1f1f1f;
        --savings-bg:      #f0fff4;
        --savings-border:  #a8d8b0;
        --savings-text:    #1a6a28;
        --tag-bg:          #e8e8e8;
        --tag-text:        #888888;
        --row-shadow:      0 6px 14px rgba(0,0,0,0.1), 0 -6px 14px rgba(0,0,0,0.1);
      }

      html {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        font-size: 16px;
        line-height: 1.6;
        scrollbar-width: none;
      }
      html::-webkit-scrollbar { display: none; }

      body { min-height: 100vh; }
      a { color: inherit; text-decoration: none; }

      /* ── NAV ── */

      nav {
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 clamp(1.5rem, 5vw, 4rem);
        height: 60px;
        background: var(--nav-bg);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }

      .nav-left {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }

      .nav-logo {
        font-size: 0.8125rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text);
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 0.125rem;
      }

      .nav-link {
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text-muted);
        padding: 0.25rem 0.625rem;
        transition: color 0.15s;
        letter-spacing: 0.02em;
      }
      .nav-link:hover { color: var(--text-secondary); }

      .nav-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.45rem 1rem;
        font-size: 0.8125rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        border: 1px solid var(--border-strong);
        color: var(--text-secondary);
        background: transparent;
        transition: border-color 0.15s, color 0.15s;
        cursor: pointer;
      }
      .nav-cta:hover { border-color: var(--text-secondary); color: var(--text); }

      .nav-right {
        display: flex;
        align-items: center;
        gap: 0.5rem;
      }

      .theme-toggle {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 32px;
        height: 32px;
        background: transparent;
        border: 1px solid var(--border-strong);
        color: var(--text-muted);
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
        padding: 0;
      }
      .theme-toggle:hover {
        border-color: var(--text-secondary);
        color: var(--text-secondary);
      }
      .theme-toggle .icon-sun,
      .theme-toggle .icon-moon { display: none; }
      html[data-theme="dark"] .theme-toggle .icon-sun { display: block; }
      html[data-theme="light"] .theme-toggle .icon-moon { display: block; }
      /* When no explicit data-theme (system default) */
      html:not([data-theme]) .theme-toggle .icon-sun { display: none; }
      html:not([data-theme]) .theme-toggle .icon-moon { display: none; }
      @media (prefers-color-scheme: dark) {
        html:not([data-theme]) .theme-toggle .icon-sun { display: block; }
      }
      @media (prefers-color-scheme: light) {
        html:not([data-theme]) .theme-toggle .icon-moon { display: block; }
      }

      /* ── SHARED ── */

      .eyebrow {
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-muted);
      }

      .section-header { margin-bottom: 3.5rem; }
      .section-header .eyebrow { margin-bottom: 1rem; }
      .section-header h2 {
        font-size: clamp(1.5rem, 3vw, 2.25rem);
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.2;
        color: var(--text);
        max-width: 480px;
      }

      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.7rem 1.5rem;
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.01em;
        background: var(--text);
        color: var(--bg);
        border: 1px solid transparent;
        cursor: pointer;
        transition: background 0.15s;
      }
      .btn-primary:hover { background: var(--btn-hover); }

      .btn-ghost {
        display: inline-flex;
        align-items: center;
        padding: 0.7rem 1.5rem;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-secondary);
        border: 1px solid var(--border-strong);
        background: transparent;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
      }
      .btn-ghost:hover { border-color: var(--text-secondary); color: var(--text); }

      /* ── HERO ── */

      .hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: clamp(5rem, 14vw, 10rem) clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
      }

      .hero .eyebrow { margin-bottom: 1.75rem; }

      .hero h1 {
        font-size: clamp(2.25rem, 6vw, 4.5rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.15;
        color: var(--text);
        max-width: 760px;
        margin-bottom: 1.5rem;
      }
      .hero h1 span { color: var(--text-secondary); }

      .region-rotate {
        display: inline-block;
        width: 6.5ch;
        text-align: left;
        color: var(--text-secondary);
        transition: opacity 0.5s ease;
      }

      .hero-sub {
        font-size: clamp(0.9375rem, 1.5vw, 1.0625rem);
        color: var(--text-secondary);
        max-width: 520px;
        line-height: 1.7;
        margin-bottom: 2.75rem;
      }

      .hero-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        justify-content: center;
      }

      /* ── STATEMENT ── */

      .statement {
        padding: clamp(4rem, 10vw, 7rem) clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
      }
      .statement .eyebrow { margin-bottom: 1rem; }

      .statement-content {
        background: var(--surface-2);
        border: 1px dashed var(--border-strong);
        border-radius: 4px;
        padding: 2rem;
        max-width: 680px;
        font-size: clamp(1rem, 2vw, 1.125rem);
        line-height: 1.8;
        color: var(--text-secondary);
        min-height: 120px;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .statement-content.has-content {
        background: var(--bg);
        border-color: var(--border);
        border-style: solid;
        color: var(--text);
      }

      /* ── FEATURES ── */

      .features {
        padding: clamp(4rem, 10vw, 7rem) clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
      }

      .feature-card {
        background: var(--bg);
        padding: 2.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        transition: background 0.15s;
      }
      .feature-card:hover { background: var(--surface); }

      .feature-icon {
        width: 34px;
        height: 34px;
        color: var(--text-secondary);
        flex-shrink: 0;
      }

      .feature-card h3 {
        font-size: 0.9375rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text);
      }

      .feature-card p {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.65;
      }

      /* ── COMPARISON ── */

      .comparison {
        padding: clamp(4rem, 10vw, 7rem) clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
      }

      .comparison-controls {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 2rem 3rem;
        max-width: 840px;
        margin-bottom: 3rem;
      }

      .control-group { display: flex; flex-direction: column; gap: 0.5rem; }

      .control-label {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
      }
      .control-label span {
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .control-value {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text);
      }

      .tier-toggle {
        display: flex;
        gap: 0.375rem;
        margin-top: 0.25rem;
      }

      .tier-btn {
        padding: 0.25rem 0.875rem;
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        border: 1px solid var(--border-strong);
        background: transparent;
        color: var(--text-muted);
        cursor: pointer;
        transition: background 0.12s, color 0.12s, border-color 0.12s;
      }
      .tier-btn.active {
        background: var(--text);
        border-color: var(--text);
        color: var(--bg);
      }

      .slider {
        -webkit-appearance: none;
        appearance: none;
        width: 100%;
        height: 2px;
        background: var(--border-strong);
        outline: none;
        cursor: pointer;
      }
      .slider::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 14px;
        height: 14px;
        background: var(--text);
        cursor: pointer;
      }
      .slider::-moz-range-thumb {
        width: 14px;
        height: 14px;
        background: var(--text);
        border: none;
        cursor: pointer;
        border-radius: 0;
      }

      .comparison-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        margin-bottom: 1.5rem;
      }

      .comp-card {
        background: var(--bg);
        padding: 2rem;
        display: flex;
        flex-direction: column;
      }
      .comp-card.featured { background: var(--surface); }

      .comp-platform {
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
      }
      .comp-card.featured .comp-platform { color: var(--text-secondary); }

      .comp-price {
        font-family: 'JetBrains Mono', monospace;
        font-size: clamp(1.75rem, 3vw, 2.5rem);
        font-weight: 500;
        color: var(--text);
        letter-spacing: -0.04em;
        line-height: 1;
        margin-bottom: 0.3rem;
      }

      .comp-unit {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-bottom: 1.75rem;
      }

      .comp-breakdown {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        border-top: 1px solid var(--border);
        padding-top: 1.25rem;
        padding-bottom: 1.25rem;
        flex: 1;
      }

      .comp-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
      }
      .comp-row span:first-child {
        font-size: 0.8rem;
        color: var(--text-muted);
      }
      .comp-row span:last-child {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: var(--text-secondary);
      }

      .comp-note {
        font-size: 0.7rem;
        color: var(--text-muted);
        padding-top: 1rem;
        border-top: 1px solid var(--border);
        line-height: 1.55;
      }

      .savings-row {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }

      .savings-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1.25rem;
        background: var(--savings-bg);
        border: 1px solid var(--savings-border);
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--text-secondary);
        width: fit-content;
        flex-wrap: wrap;
      }
      .savings-text {
        color: var(--savings-text);
        font-family: 'JetBrains Mono', monospace;
        font-weight: 500;
      }

      .savings-caption {
        font-size: 0.725rem;
        color: var(--text-muted);
        max-width: 680px;
        line-height: 1.5;
      }

      /* ── MISSION ── */

      .mission {
        padding: clamp(4.5rem, 10vw, 8rem) clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
      }
      .mission .eyebrow { margin-bottom: 1rem; }

      .mission-statement {
        font-size: clamp(1.0625rem, 2vw, 1.375rem);
        color: var(--text-secondary);
        max-width: 680px;
        line-height: 1.75;
      }
      .mission-statement strong { color: var(--text); font-weight: 600; }

      /* ── CTA BAND ── */

      .cta-band {
        padding: clamp(4rem, 10vw, 7rem) clamp(1.5rem, 5vw, 4rem);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 2rem;
        border-bottom: 1px solid var(--border);
      }
      .cta-band h2 {
        font-size: clamp(1.625rem, 3.5vw, 2.5rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.15;
        max-width: 520px;
      }
      .cta-band p {
        font-size: 0.9375rem;
        color: var(--text-secondary);
        max-width: 400px;
        line-height: 1.7;
        margin-top: -0.75rem;
      }

      /* ── FOOTER ── */

      footer {
        padding: 1.75rem clamp(1.5rem, 5vw, 4rem);
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: start;
        gap: 1rem 2rem;
      }

      .footer-left {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
      }

      .footer-eu {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8rem;
        color: var(--text-secondary);
        font-weight: 500;
      }
      .footer-eu svg { flex-shrink: 0; }

      .footer-copy {
        font-size: 0.75rem;
        color: var(--text-muted);
      }

      .footer-link {
        font-size: 0.8125rem;
        color: var(--text-muted);
        transition: color 0.15s;
        align-self: center;
      }
      .footer-link:hover { color: var(--text-secondary); }

      .footer-links {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex-wrap: wrap;
        align-self: center;
      }

      /* ── PRICING TIERS ── */

      .pricing-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        margin-bottom: 1px;
      }

      .pricing-card {
        background: var(--bg);
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 0;
      }
      .pricing-card.featured { background: var(--surface); }

      .pricing-card-name {
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
      }
      .pricing-card.featured .pricing-card-name { color: var(--text); }

      .pricing-card-price {
        font-family: 'JetBrains Mono', monospace;
        font-size: clamp(1.75rem, 2.5vw, 2.25rem);
        font-weight: 500;
        letter-spacing: -0.04em;
        line-height: 1;
        color: var(--text);
        margin-bottom: 0.25rem;
      }

      .pricing-card-unit {
        font-size: 0.75rem;
        color: var(--text-secondary);
        margin-bottom: 1.75rem;
      }

      .pricing-card-specs {
        display: flex;
        flex-direction: column;
        gap: 0;
        border-top: 1px solid var(--border);
        flex: 1;
      }

      .pricing-spec {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 0.5rem 0;
        border-bottom: 1px solid var(--border);
        gap: 0.5rem;
      }
      .pricing-spec-label {
        font-size: 0.775rem;
        color: var(--text-secondary);
        flex-shrink: 0;
      }
      .pricing-spec-val {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: var(--text);
        text-align: right;
      }

      .pricing-card-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        margin-top: 1.75rem;
        padding: 0.6rem 1rem;
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        border: 1px solid var(--border-strong);
        color: var(--text-secondary);
        background: transparent;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
        text-decoration: none;
      }
      .pricing-card-cta:hover { border-color: var(--text-secondary); color: var(--text); }
      .pricing-card.featured .pricing-card-cta {
        background: var(--text);
        border-color: var(--text);
        color: var(--bg);
      }
      .pricing-card.featured .pricing-card-cta:hover { background: var(--btn-hover); }

      /* ── CUSTOM TIER CALCULATOR ── */

      .custom-tier {
        display: flex;
        flex-direction: column;
        gap: 0;
        background: var(--bg);
        padding: 2rem;
      }

      .custom-tier-header {
        margin-bottom: 2rem;
      }

      .custom-tier h3 {
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-secondary);
        margin-bottom: 1.5rem;
      }

      .custom-tier-desc {
        font-size: 0.8rem;
        color: var(--text-secondary);
        margin-bottom: 1.75rem;
        line-height: 1.6;
      }

      .calculator-section {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
      }

      .calc-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .calc-label {
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted);
      }

      .calc-server-select {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
        gap: 0.5rem;
      }

      .calc-server-btn {
        padding: 0.75rem 1rem;
        background: var(--bg);
        border: 1px solid var(--border-strong);
        color: var(--text-secondary);
        cursor: pointer;
        font-size: 0.75rem;
        font-weight: 500;
        transition: all 0.15s;
      }
      .calc-server-btn:hover {
        border-color: var(--text-secondary);
        color: var(--text);
      }
      .calc-server-btn.selected {
        background: var(--text);
        border-color: var(--text);
        color: var(--bg);
      }

      .calc-server-specs {
        font-size: 0.7rem;
        color: var(--text-muted);
        margin-top: 0.3rem;
      }

      .calc-slider-group {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
      }

      .calc-slider-label {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .calc-slider-label-text {
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--text-secondary);
      }

      .calc-slider-value {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: var(--text);
        font-weight: 600;
      }

      .calc-slider {
        width: 100%;
        height: 2px;
        background: var(--border-strong);
        border-radius: 1px;
        outline: none;
        -webkit-appearance: none;
        appearance: none;
      }
      .calc-slider::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--text);
        cursor: pointer;
      }
      .calc-slider::-moz-range-thumb {
        width: 14px;
        height: 14px;
        border-radius: 50%;
        background: var(--text);
        border: none;
        cursor: pointer;
      }

      .calc-summary {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        padding: 1.25rem 0;
        border-top: 1px solid var(--border);
        border-bottom: 1px solid var(--border);
        margin: 1.5rem 0;
      }

      .calc-summary-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        font-size: 0.8rem;
      }

      .calc-summary-label {
        color: var(--text-muted);
      }

      .calc-summary-value {
        font-family: 'JetBrains Mono', monospace;
        color: var(--text);
        font-weight: 500;
      }

      .calc-data-tier-notice {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        font-size: 0.7rem;
        color: var(--text-muted);
        padding: 0.75rem 1rem;
        background: var(--bg);
        border: 1px solid var(--border);
      }

      .calc-data-tier-notice-title {
        font-weight: 600;
        color: var(--text-secondary);
      }

      .calc-total-price {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.3rem;
        margin-top: 1rem;
      }

      .calc-total-label {
        font-size: 0.75rem;
        color: var(--text-muted);
        letter-spacing: 0.08em;
      }

      .calc-total-amount {
        font-family: 'JetBrains Mono', monospace;
        font-size: 2rem;
        font-weight: 500;
        color: var(--text);
        letter-spacing: -0.04em;
      }

      .calc-monthly-unit {
        font-size: 0.75rem;
        color: var(--text-secondary);
      }

      .custom-tier-cta {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        margin-top: 1.75rem;
        padding: 0.6rem 1rem;
        font-size: 0.8rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        border: 1px solid var(--text);
        color: var(--bg);
        background: var(--text);
        cursor: pointer;
        transition: background 0.15s;
        text-decoration: none;
        align-self: flex-start;
      }
      .custom-tier-cta:hover { background: var(--btn-hover); color: var(--bg); }

      .pricing-storage {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem 2rem;
        background: var(--bg);
        border: 1px solid var(--border);
        border-top: none;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .pricing-storage-left {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }
      .pricing-storage-label {
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-muted);
      }
      .pricing-storage-desc {
        font-size: 0.8rem;
        color: var(--text-secondary);
      }
      .pricing-storage-val {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.875rem;
        color: var(--text);
        white-space: nowrap;
      }

      .overage-note {
        font-size: 0.7rem;
        color: var(--text-muted);
        margin-top: 0.3rem;
      }

      .how-it-works {
        margin-top: 3rem;
        margin-bottom: 3rem;
        max-width: 680px;
      }
      .how-it-works .eyebrow { margin-bottom: 1.25rem; }
      .how-it-works h3 {
        font-size: 1.125rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text);
        margin-bottom: 1rem;
      }
      .how-it-works p {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.75;
        margin-bottom: 0.75rem;
      }
      .how-it-works p:last-child { margin-bottom: 0; }
      .how-it-works strong { color: var(--text); font-weight: 600; }

      .compare-table-wrap {
        overflow-x: auto;
        margin-top: 3rem;
      }
      .compare-table {
        width: 100%;
        border-collapse: collapse;
        border: 1px solid var(--border);
        min-width: 640px;
      }
      .compare-table th,
      .compare-table td {
        padding: 0.65rem 1.25rem;
        text-align: left;
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
      }
      .compare-table thead th {
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-muted);
        background: var(--surface);
      }
      .compare-table thead th.highlight {
        background: var(--surface-2);
        color: var(--text-secondary);
      }
      .compare-table td:first-child {
        font-size: 0.8rem;
        color: var(--text-secondary);
        background: var(--bg);
      }
      .compare-table td:not(:first-child) {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.775rem;
        color: var(--text);
        background: var(--bg);
      }
      .compare-table td.highlight {
        background: var(--surface);
      }
      .compare-table tbody tr:last-child td { border-bottom: none; }
      .compare-table tbody tr {
        position: relative;
        z-index: 0;
      }
      .compare-table tbody tr:hover {
        z-index: 2;
      }
      .compare-table td {
        transition: background 0.15s ease, box-shadow 0.15s ease;
        position: relative;
      }
      .compare-table tbody tr:hover td {
        background: var(--surface-2);
        z-index: 2;
        box-shadow: var(--row-shadow);
      }
      .compare-note {
        font-size: 0.7rem;
        color: var(--text-muted);
        margin-top: 0.75rem;
        line-height: 1.5;
      }

      @media (max-width: 900px) {
        .pricing-grid { grid-template-columns: repeat(2, 1fr); }
      }
      @media (max-width: 560px) {
        .pricing-grid { grid-template-columns: 1fr; }
      }

      /* ── PLANS & RATES ── */

      .plans {
        padding: clamp(4rem, 10vw, 7rem) clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
      }

      .plan-header-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        margin-bottom: 3rem;
      }

      .plan-header-card {
        background: var(--bg);
        padding: 2rem;
      }
      .plan-header-card.featured { background: var(--surface); }

      .plan-card-name {
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 1.25rem;
      }
      .plan-header-card.featured .plan-card-name { color: var(--text-secondary); }

      .plan-card-price {
        font-family: 'JetBrains Mono', monospace;
        font-size: clamp(1.75rem, 3vw, 2.5rem);
        font-weight: 500;
        color: var(--text);
        letter-spacing: -0.04em;
        line-height: 1;
        margin-bottom: 0.3rem;
      }

      .plan-card-unit {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
      }

      .plan-card-feature {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.825rem;
        color: var(--text-secondary);
        padding: 0.35rem 0;
        border-top: 1px solid var(--border);
      }
      .plan-card-feature:last-child { border-bottom: 1px solid var(--border); }
      .plan-check { color: var(--savings-text); font-weight: 600; font-size: 0.75rem; }

      .rates-block-label {
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-secondary);
        margin-bottom: 1rem;
        max-width: 680px;
        margin-left: auto;
        margin-right: auto;
        text-align: center;
      }

      .rates-grid {
        display: flex;
        flex-direction: column;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        margin: 0 auto 3rem;
        max-width: 680px;
      }

      .rates-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        position: relative;
        z-index: 0;
      }
      .rates-row:hover {
        z-index: 2;
      }

      .rate-label, .rate-val {
        padding: 0.7rem 1.25rem;
        transition: background 0.15s ease, box-shadow 0.15s ease;
        position: relative;
      }
      .rates-row:hover .rate-label,
      .rates-row:hover .rate-val {
        background: var(--surface-2);
        box-shadow: var(--row-shadow);
        z-index: 2;
      }
      .rate-label {
        background: var(--bg);
        font-size: 0.8rem;
        color: var(--text-secondary);
      }
      .rate-val {
        background: var(--bg);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        color: var(--text);
      }

      .limits-table-wrap { overflow-x: auto; max-width: 680px; margin: 0 auto; }

      .limits-table {
        width: 100%;
        border-collapse: collapse;
        border: 1px solid var(--border);
      }
      .limits-table th,
      .limits-table td {
        padding: 0.65rem 1.25rem;
        text-align: left;
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
      }
      .limits-table thead th {
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-muted);
        background: var(--surface);
      }
      .limits-table thead th:last-child { background: var(--surface-2); }
      .limits-table td:first-child {
        font-size: 0.8rem;
        color: var(--text-secondary);
        width: 50%;
        background: var(--bg);
      }
      .limits-table td:not(:first-child) {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        color: var(--text);
        background: var(--bg);
      }
      .limits-table td:last-child { background: var(--surface); }
      .limits-table tbody tr:last-child td { border-bottom: none; }
      .limits-table tbody tr {
        position: relative;
        z-index: 0;
      }
      .limits-table tbody tr:hover {
        z-index: 2;
      }
      .limits-table td {
        transition: background 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
        position: relative;
      }
      .limits-table tbody tr:hover td {
        background: var(--surface-2);
        border-color: var(--border-strong);
        z-index: 2;
        box-shadow: var(--row-shadow);
      }
      .limits-table tbody tr:hover td:last-child {
        background: var(--surface-2);
      }
      .rate-tag {
        display: inline-block;
        font-size: 0.575rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted);
        border: 1px solid var(--border-strong);
        padding: 0.1rem 0.35rem;
        vertical-align: middle;
        margin-left: 0.4rem;
      }

      .compute-examples {
        max-width: 680px;
        margin: -1px auto 3rem;
        border: 1px solid var(--border);
        border-top: none;
        display: flex;
        flex-direction: column;
        gap: 1px;
        background: var(--border);
      }

      .compute-example {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 0.55rem 1.25rem;
        background: var(--bg);
        gap: 1rem;
      }

      .compute-example-label {
        font-size: 0.775rem;
        color: var(--text-muted);
      }

      .compute-example-val {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.775rem;
        color: var(--text-secondary);
        white-space: nowrap;
      }

      .lim-check { color: var(--savings-text); font-weight: 600; }
      .lim-dash  { color: var(--text-muted); }

      /* ── PRODUCTS ── */

      .products {
        padding: clamp(4rem, 10vw, 7rem) clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
      }

      .products-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
      }

      .product-card {
        background: var(--bg);
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 0;
        transition: background 0.15s;
        position: relative;
      }
      .product-card:hover { background: var(--surface); }

      .product-card-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.625rem;
        font-weight: 500;
        color: var(--text-muted);
        letter-spacing: 0.12em;
        margin-bottom: 1.75rem;
      }

      .product-card-icon {
        display: none;
      }

      .product-card h3 {
        font-size: 0.9375rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text);
        margin-bottom: 0.5rem;
      }

      .product-card p {
        font-size: 0.8125rem;
        color: var(--text-secondary);
        line-height: 1.6;
        flex: 1;
        margin-bottom: 1.5rem;
      }

      .product-card-link {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted);
        transition: color 0.15s;
        margin-top: auto;
      }
      .product-card:hover .product-card-link { color: var(--text-secondary); }

      /* ── CASE STUDIES ── */

      .case-studies {
        padding: clamp(3.5rem, 8vw, 6rem) clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
      }

      .case-studies-grid {
        display: flex;
        flex-direction: column;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        margin-top: 2rem;
      }

      .case-study-card {
        display: grid;
        grid-template-columns: 3rem 1fr;
        background: var(--bg);
        transition: background 0.15s;
      }
      .case-study-card:hover { background: var(--surface); }

      .case-study-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        font-weight: 500;
        color: var(--text-muted);
        padding: 1.5rem 0 1.5rem 1.25rem;
        align-self: start;
      }

      .case-study-body {
        padding: 1.5rem;
        border-left: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }

      .case-study-body h3 {
        font-size: 0.9375rem;
        font-weight: 600;
        color: var(--text);
        letter-spacing: -0.01em;
      }

      .case-study-body p {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.65;
        max-width: 560px;
      }

      .case-study-link {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted);
        transition: color 0.15s;
        margin-top: 0.25rem;
      }
      .case-study-card:hover .case-study-link { color: var(--text-secondary); }

      /* ── RESPONSIVE ── */

      @media (max-width: 768px) {
        .products-grid { grid-template-columns: repeat(2, 1fr); }
        .nav-links { display: none; }
        .comparison-cards {
          grid-template-columns: 1fr;
        }
        .comp-card.featured {
          order: -1;
        }
        .comparison-controls {
          grid-template-columns: 1fr;
        }
        .pricing-grid {
          grid-template-columns: 1fr;
        }
        .calc-server-select {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 640px) {
        .products-grid { grid-template-columns: 1fr; }
        .hero-actions { flex-direction: column; width: 100%; }
        .btn-primary, .btn-ghost { width: 100%; justify-content: center; }
        .section-header h2 { max-width: 100%; }
        footer { grid-template-columns: 1fr; }
        .plan-header-cards { grid-template-columns: 1fr; }
        .rates-row { grid-template-columns: 1fr; }
        .calc-summary-row {
          flex-direction: column;
          gap: 0.3rem;
        }
        .calc-total-price {
          align-items: flex-end;
        }
      }
    </style>
  </head>
  <body>

    <nav>
      <div class="nav-left">
        <a href="/" class="nav-logo">AroDeploy</a>
        <div class="nav-links">
          <!-- <a href="#products" class="nav-link">Products</a>
          <a href="#case-studies" class="nav-link">Case Studies</a>
          <a href="#pricing" class="nav-link">Pricing</a> -->
        </div>
      </div>
      <div class="nav-right">
        <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
          <svg class="icon-sun" width="24" height="24" viewBox="0 0 16 16" fill="none">
            <circle cx="8" cy="8" r="3" stroke="currentColor" stroke-width="1.3"/>
            <path d="M8 1.5v1.5M8 13v1.5M1.5 8H3M13 8h1.5M3.17 3.17l1.06 1.06M11.77 11.77l1.06 1.06M3.17 12.83l1.06-1.06M11.77 4.23l1.06-1.06" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
          </svg>
          <svg class="icon-moon" width="24" height="24" viewBox="0 0 16 16" fill="none">
            <path d="M13.36 10.06A5.5 5.5 0 015.94 2.64a6 6 0 107.42 7.42z" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <a href={links.console} class="nav-cta">
          Open Console
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
            <path d="M2.5 9.5L9.5 2.5M9.5 2.5H4M9.5 2.5V8" stroke="currentColor" stroke-width="1.25" stroke-linecap="square"/>
          </svg>
        </a>
      </div>
    </nav>

    <main>
      <section class="hero">
        <p class="eyebrow">Developer Infrastructure</p>
        <h1>Git push. We handle<br />the rest in <span class="region-rotate" id="region-rotate">Germany</span></h1>
        <p class="hero-sub">
          Zero-downtime deploys, CDN, custom domains, and preview environments.
        </p>
        <div class="hero-actions">
          <a href={links.console} class="btn-primary">
            Open Console
            <svg width="13" height="13" viewBox="0 0 13 13" fill="none">
              <path d="M2.5 10.5L10.5 2.5M10.5 2.5H4.5M10.5 2.5V8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="square"/>
            </svg>
          </a>
          <!-- <a href="#pricing" class="btn-ghost">See pricing</a> -->
        </div>
      </section>

      <section class="statement">
        <p class="eyebrow">Our Vision</p>
        <div class="statement-content" id="statement-content">
          We solve the issue of observability, tool complextion
        </div>
      </section>

      <section class="features">
        <div class="section-header">
          <p class="eyebrow">Platform Features</p>
          <h2>Everything you need. Nothing you don't.</h2>
        </div>
