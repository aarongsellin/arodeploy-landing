    <script define:vars={{ pricing }}>
      (function () {
        const vcpuEl  = document.getElementById('vcpu');
        const ramEl   = document.getElementById('ram');
        const bwEl    = document.getElementById('bw');
        const seatsEl = document.getElementById('seats');

        const aro = pricing.aro;
        const rw  = pricing.railway;
        const vc  = pricing.vercel;
        let aroTier = 'pro';

        function calcAroCompute(v, r) {
          return aro.baseFee + v * aro.cpuRate + r * aro.ramRate;
        }
        function calcRailwayCompute(v, r) {
          return rw.baseFee + v * rw.cpuMonthlyRate + r * rw.ramMonthlyRate;
        }
        function calcVercelCompute(v, r) {
          const gbHr = v * r * vc.hoursPerMonth * vc.avgUtilization;
          const extra = Math.max(0, gbHr - vc.includedGbHr) * vc.overageRate;
          return vc.basePlan + extra;
        }
        function calcBw(bw, includedGb, overageRate) {
          return Math.max(0, bw - includedGb) * overageRate;
        }

        function fmt(n)  { return Math.round(n).toLocaleString('en-US'); }
        function fmtd(n) { return '$' + fmt(n); }

        function update() {
          const v     = parseInt(vcpuEl.value,  10);
          const r     = parseInt(ramEl.value,   10);
          const bw    = parseInt(bwEl.value,    10);
          const seats = parseInt(seatsEl.value, 10);

          document.getElementById('vcpu-val').textContent  = v + ' vCPU';
          document.getElementById('ram-val').textContent   = r + ' GB';
          document.getElementById('bw-val').textContent    = bw.toLocaleString('en-US') + ' GB';
          document.getElementById('seats-val').textContent = seats + (seats === 1 ? ' seat — Pro' : ' seats — Pro');

          // Vercel
          const vcBw    = calcBw(bw, vc.bandwidthIncludedGb, vc.bandwidthOverageRate);
          const vcTotal = calcVercelCompute(v, r) + vcBw;
          const vcCompute = Math.max(0, (v * r * vc.hoursPerMonth * vc.avgUtilization - vc.includedGbHr) * vc.overageRate);
          document.getElementById('vc-total').textContent      = fmt(vcTotal);
          document.getElementById('vc-compute').textContent    = fmtd(vcCompute);
          document.getElementById('vc-bw-label').textContent   = bw.toLocaleString('en-US');
          document.getElementById('vc-bw').textContent         = vcBw > 0 ? fmtd(vcBw) : 'Incl.';

          // Railway
          const rwBw    = calcBw(bw, rw.bandwidthIncludedGb, rw.bandwidthOverageRate);
          const rwTotal = calcRailwayCompute(v, r) + rwBw;
          document.getElementById('rw-total').textContent      = fmt(rwTotal);
          document.getElementById('rw-vcpu-label').textContent = v;
          document.getElementById('rw-ram-label').textContent  = r;
          document.getElementById('rw-cpu').textContent        = fmtd(v * rw.cpuMonthlyRate);
          document.getElementById('rw-ram').textContent        = fmtd(r * rw.ramMonthlyRate);
          document.getElementById('rw-bw-label').textContent   = bw.toLocaleString('en-US');
          document.getElementById('rw-bw').textContent         = rwBw > 0 ? fmtd(rwBw) : 'Incl.';

          // AroDeploy
          const aroBwCfg = aro.bandwidth[aroTier];
          const aroBw    = calcBw(bw, aroBwCfg.includedGb, aroBwCfg.overageRate);
          const aroSeats = aroTier === 'pro' ? seats * aro.seatRate : 0;
          const aroTotal = calcAroCompute(v, r) + aroBw + aroSeats;
          document.getElementById('aro-total').textContent       = fmt(aroTotal);
          document.getElementById('aro-vcpu-label').textContent  = v;
          document.getElementById('aro-ram-label').textContent   = r;
          document.getElementById('aro-cpu').textContent         = fmtd(v * aro.cpuRate);
          document.getElementById('aro-ram-cost').textContent    = fmtd(r * aro.ramRate);
          document.getElementById('aro-bw-label').textContent    = bw.toLocaleString('en-US');
          document.getElementById('aro-bw').textContent          = aroBw > 0 ? fmtd(aroBw) : 'Incl.';
          document.getElementById('aro-seats-label').textContent = seats;
          document.getElementById('aro-seats-cost').textContent  = aroTier === 'pro' ? fmtd(aroSeats) : 'N/A';

          // Savings vs Railway
          const savingsPct = Math.round((1 - aroTotal / rwTotal) * 100);
          const savingsYr  = Math.round((rwTotal - aroTotal) * 12);
          document.getElementById('savings-pct').textContent = savingsPct + '%';
          document.getElementById('savings-yr').textContent  = fmtd(savingsYr) + '/yr';
        }

        vcpuEl.addEventListener('input', update);
        ramEl.addEventListener('input', update);
        bwEl.addEventListener('input', update);
        seatsEl.addEventListener('input', update);

        document.getElementById('tier-free').addEventListener('click', function () {
          aroTier = 'free';
          document.getElementById('tier-free').classList.add('active');
          document.getElementById('tier-pro').classList.remove('active');
          document.getElementById('aro-tier-label').textContent  = 'Trial';
          document.getElementById('seats-group').style.display   = 'none';
          document.getElementById('aro-seats-row').style.display = 'none';
          update();
        });
        document.getElementById('tier-pro').addEventListener('click', function () {
          aroTier = 'pro';
          document.getElementById('tier-pro').classList.add('active');
          document.getElementById('tier-free').classList.remove('active');
          document.getElementById('aro-tier-label').textContent  = 'Pro';
          document.getElementById('seats-group').style.display   = '';
          document.getElementById('aro-seats-row').style.display = '';
          update();
        });

        update();
      })();
    </script>

  </body>
</html>
