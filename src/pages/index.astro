    <script>
      /* ── Region rotation ── */
      (() => {
        const regions = ['US East', 'US West', 'Finland', 'Singapore', 'Germany'];
        const el = document.getElementById('region-rotate');
        if (!el) return;
        let idx = 0;
        setInterval(() => {
          el.style.opacity = '0';
          setTimeout(() => {
            idx = (idx + 1) % regions.length;
            el.textContent = regions[idx];
            el.style.opacity = '1';
          }, 500);
        }, 3000);
      })();

      /* ── Theme toggle ── */
      (() => {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', () => {
          const html = document.documentElement;
          const current = html.getAttribute('data-theme');
          let next;
          if (!current) {
            /* System default — toggle to the opposite */
            next = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'light' : 'dark';
          } else {
            next = current === 'dark' ? 'light' : 'dark';
          }
          html.setAttribute('data-theme', next);
          localStorage.setItem('arodeploy-theme', next);
        });
      })();
    </script>

