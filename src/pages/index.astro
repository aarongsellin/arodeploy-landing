---
import { pricing } from '../config/pricing.ts';
import { products } from '../config/products.ts';
const year = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>AroDeploy — Deployment Infrastructure. Flat Rate. No Surprises.</title>
    <meta name="description" content="AroDeploy is a full deployment engine with zero-downtime releases, preview environments, and smart builds — hosted on European infrastructure at a flat, predictable monthly rate." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      /* ── COLOR TOKENS: DARK (default) ── */
      :root {
        --bg:              #0a0a0a;
        --surface:         #111111;
        --surface-2:       #171717;
        --border:          #1f1f1f;
        --border-strong:   #2e2e2e;
        --text:            #f0f0f0;
        --text-secondary:  #888888;
        --text-muted:      #484848;
        --nav-bg:          rgba(10, 10, 10, 0.92);
        --btn-hover:       #d0d0d0;
        --savings-bg:      #0d1f0d;
        --savings-border:  #1a3a1a;
        --savings-text:    #6dc46d;
        --tag-bg:          #1a1a1a;
        --tag-text:        #555555;
        --row-shadow:      0 6px 14px rgba(0,0,0,0.45), 0 -6px 14px rgba(0,0,0,0.45);
      }

      /* ── COLOR TOKENS: LIGHT ── */
      @media (prefers-color-scheme: light) {
        :root {
          --bg:              #f5f5f5;
          --surface:         #ffffff;
          --surface-2:       #ebebeb;
          --border:          #e0e0e0;
          --border-strong:   #c8c8c8;
          --text:            #0a0a0a;
          --text-secondary:  #555555;
          --text-muted:      #999999;
          --nav-bg:          rgba(245, 245, 245, 0.92);
          --btn-hover:       #1f1f1f;
          --savings-bg:      #f0fff4;
          --savings-border:  #a8d8b0;
          --savings-text:    #1a6a28;
          --tag-bg:          #e8e8e8;
          --tag-text:        #888888;
          --row-shadow:      0 6px 14px rgba(0,0,0,0.1), 0 -6px 14px rgba(0,0,0,0.1);
        }
      }

      html {
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        font-size: 16px;
        line-height: 1.6;
        scrollbar-width: none;
      }
      html::-webkit-scrollbar { display: none; }

      body { min-height: 100vh; }
      a { color: inherit; text-decoration: none; }

      /* ── NAV ── */

      nav {
        position: sticky;
        top: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 clamp(1.5rem, 5vw, 4rem);
        height: 60px;
        background: var(--nav-bg);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }

      .nav-left {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }

      .nav-logo {
        font-size: 0.8125rem;
        font-weight: 700;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--text);
      }

      .nav-links {
        display: flex;
        align-items: center;
        gap: 0.125rem;
      }

      .nav-link {
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text-muted);
        padding: 0.25rem 0.625rem;
        transition: color 0.15s;
        letter-spacing: 0.02em;
      }
      .nav-link:hover { color: var(--text-secondary); }

      .nav-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.45rem 1rem;
        font-size: 0.8125rem;
        font-weight: 500;
        letter-spacing: 0.02em;
        border: 1px solid var(--border-strong);
        color: var(--text-secondary);
        background: transparent;
        transition: border-color 0.15s, color 0.15s;
        cursor: pointer;
      }
      .nav-cta:hover { border-color: var(--text-secondary); color: var(--text); }

      /* ── SHARED ── */

      .eyebrow {
        font-size: 0.6875rem;
        font-weight: 600;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-muted);
      }

      .section-header { margin-bottom: 3.5rem; }
      .section-header .eyebrow { margin-bottom: 1rem; }
      .section-header h2 {
        font-size: clamp(1.5rem, 3vw, 2.25rem);
        font-weight: 700;
        letter-spacing: -0.025em;
        line-height: 1.2;
        color: var(--text);
        max-width: 480px;
      }

      .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.7rem 1.5rem;
        font-size: 0.875rem;
        font-weight: 600;
        letter-spacing: 0.01em;
        background: var(--text);
        color: var(--bg);
        border: 1px solid transparent;
        cursor: pointer;
        transition: background 0.15s;
      }
      .btn-primary:hover { background: var(--btn-hover); }

      .btn-ghost {
        display: inline-flex;
        align-items: center;
        padding: 0.7rem 1.5rem;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-secondary);
        border: 1px solid var(--border-strong);
        background: transparent;
        cursor: pointer;
        transition: border-color 0.15s, color 0.15s;
      }
      .btn-ghost:hover { border-color: var(--text-secondary); color: var(--text); }

      /* ── HERO ── */

      .hero {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: clamp(5rem, 14vw, 10rem) clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
      }

      .hero .eyebrow { margin-bottom: 1.75rem; }

      .hero h1 {
        font-size: clamp(2.25rem, 6vw, 4.5rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.08;
        color: var(--text);
        max-width: 760px;
        margin-bottom: 1.5rem;
      }
      .hero h1 span { color: var(--text-secondary); }

      .hero-sub {
        font-size: clamp(0.9375rem, 1.5vw, 1.0625rem);
        color: var(--text-secondary);
        max-width: 520px;
        line-height: 1.7;
        margin-bottom: 2.75rem;
      }

      .hero-actions {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        flex-wrap: wrap;
        justify-content: center;
      }

      /* ── FEATURES ── */

      .features {
        padding: clamp(4rem, 10vw, 7rem) clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
      }

      .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(100%, 280px), 1fr));
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
      }

      .feature-card {
        background: var(--bg);
        padding: 2.25rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        transition: background 0.15s;
      }
      .feature-card:hover { background: var(--surface); }

      .feature-icon {
        width: 34px;
        height: 34px;
        color: var(--text-secondary);
        flex-shrink: 0;
      }

      .feature-card h3 {
        font-size: 0.9375rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        color: var(--text);
      }

      .feature-card p {
        font-size: 0.875rem;
        color: var(--text-secondary);
        line-height: 1.65;
      }

      /* ── COMPARISON ── */

      .comparison {
        padding: clamp(4rem, 10vw, 7rem) clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
      }

      .comparison-controls {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
        gap: 2rem 3rem;
        max-width: 840px;
        margin-bottom: 3rem;
      }

      .control-group { display: flex; flex-direction: column; gap: 0.5rem; }

      .control-label {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
      }
      .control-label span {
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }
      .control-value {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text);
      }

      .tier-toggle {
        display: flex;
        gap: 0.375rem;
        margin-top: 0.25rem;
      }

      .tier-btn {
        padding: 0.25rem 0.875rem;
        font-family: 'Inter', sans-serif;
        font-size: 0.75rem;
        font-weight: 500;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        border: 1px solid var(--border-strong);
        background: transparent;
        color: var(--text-muted);
        cursor: pointer;
        transition: background 0.12s, color 0.12s, border-color 0.12s;
      }
      .tier-btn.active {
        background: var(--text);
        border-color: var(--text);
        color: var(--bg);
      }

      .slider {
        -webkit-appearance: none;
        appearance: none;
        width: 100%;
        height: 2px;
        background: var(--border-strong);
        outline: none;
        cursor: pointer;
      }
      .slider::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 14px;
        height: 14px;
        background: var(--text);
        cursor: pointer;
      }
      .slider::-moz-range-thumb {
        width: 14px;
        height: 14px;
        background: var(--text);
        border: none;
        cursor: pointer;
        border-radius: 0;
      }

      .comparison-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        margin-bottom: 1.5rem;
      }

      .comp-card {
        background: var(--bg);
        padding: 2rem;
        display: flex;
        flex-direction: column;
      }
      .comp-card.featured { background: var(--surface); }

      .comp-platform {
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
      }
      .comp-card.featured .comp-platform { color: var(--text-secondary); }

      .comp-price {
        font-family: 'JetBrains Mono', monospace;
        font-size: clamp(1.75rem, 3vw, 2.5rem);
        font-weight: 500;
        color: var(--text);
        letter-spacing: -0.04em;
        line-height: 1;
        margin-bottom: 0.3rem;
      }

      .comp-unit {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-bottom: 1.75rem;
      }

      .comp-breakdown {
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
        border-top: 1px solid var(--border);
        padding-top: 1.25rem;
        padding-bottom: 1.25rem;
        flex: 1;
      }

      .comp-row {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
      }
      .comp-row span:first-child {
        font-size: 0.8rem;
        color: var(--text-muted);
      }
      .comp-row span:last-child {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.75rem;
        color: var(--text-secondary);
      }

      .comp-note {
        font-size: 0.7rem;
        color: var(--text-muted);
        padding-top: 1rem;
        border-top: 1px solid var(--border);
        line-height: 1.55;
      }

      .savings-row {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }

      .savings-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1.25rem;
        background: var(--savings-bg);
        border: 1px solid var(--savings-border);
        font-size: 0.8125rem;
        font-weight: 500;
        color: var(--text-secondary);
        width: fit-content;
        flex-wrap: wrap;
      }
      .savings-text {
        color: var(--savings-text);
        font-family: 'JetBrains Mono', monospace;
        font-weight: 500;
      }

      .savings-caption {
        font-size: 0.725rem;
        color: var(--text-muted);
        max-width: 680px;
        line-height: 1.5;
      }

      /* ── MISSION ── */

      .mission {
        padding: clamp(4.5rem, 10vw, 8rem) clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
      }
      .mission .eyebrow { margin-bottom: 1rem; }

      .mission-statement {
        font-size: clamp(1.0625rem, 2vw, 1.375rem);
        color: var(--text-secondary);
        max-width: 680px;
        line-height: 1.75;
      }
      .mission-statement strong { color: var(--text); font-weight: 600; }

      /* ── CTA BAND ── */

      .cta-band {
        padding: clamp(4rem, 10vw, 7rem) clamp(1.5rem, 5vw, 4rem);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 2rem;
        border-bottom: 1px solid var(--border);
      }
      .cta-band h2 {
        font-size: clamp(1.625rem, 3.5vw, 2.5rem);
        font-weight: 700;
        letter-spacing: -0.03em;
        line-height: 1.15;
        max-width: 520px;
      }
      .cta-band p {
        font-size: 0.9375rem;
        color: var(--text-secondary);
        max-width: 400px;
        line-height: 1.7;
        margin-top: -0.75rem;
      }

      /* ── FOOTER ── */

      footer {
        padding: 1.75rem clamp(1.5rem, 5vw, 4rem);
        display: grid;
        grid-template-columns: 1fr auto;
        align-items: start;
        gap: 1rem 2rem;
      }

      .footer-left {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
      }

      .footer-eu {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.8rem;
        color: var(--text-secondary);
        font-weight: 500;
      }
      .footer-eu svg { flex-shrink: 0; }

      .footer-copy {
        font-size: 0.75rem;
        color: var(--text-muted);
      }

      .footer-link {
        font-size: 0.8125rem;
        color: var(--text-muted);
        transition: color 0.15s;
        align-self: center;
      }
      .footer-link:hover { color: var(--text-secondary); }

      /* ── PLANS & RATES ── */

      .plans {
        padding: clamp(4rem, 10vw, 7rem) clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
      }

      .plan-header-cards {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        margin-bottom: 3rem;
      }

      .plan-header-card {
        background: var(--bg);
        padding: 2rem;
      }
      .plan-header-card.featured { background: var(--surface); }

      .plan-card-name {
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 1.25rem;
      }
      .plan-header-card.featured .plan-card-name { color: var(--text-secondary); }

      .plan-card-price {
        font-family: 'JetBrains Mono', monospace;
        font-size: clamp(1.75rem, 3vw, 2.5rem);
        font-weight: 500;
        color: var(--text);
        letter-spacing: -0.04em;
        line-height: 1;
        margin-bottom: 0.3rem;
      }

      .plan-card-unit {
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-bottom: 1.5rem;
      }

      .plan-card-feature {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.825rem;
        color: var(--text-secondary);
        padding: 0.35rem 0;
        border-top: 1px solid var(--border);
      }
      .plan-card-feature:last-child { border-bottom: 1px solid var(--border); }
      .plan-check { color: var(--savings-text); font-weight: 600; font-size: 0.75rem; }

      .rates-block-label {
        font-size: 0.8125rem;
        font-weight: 600;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--text-secondary);
        margin-bottom: 1rem;
        max-width: 680px;
        margin-left: auto;
        margin-right: auto;
        text-align: center;
      }

      .rates-grid {
        display: flex;
        flex-direction: column;
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
        margin: 0 auto 3rem;
        max-width: 680px;
      }

      .rates-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        position: relative;
        z-index: 0;
      }
      .rates-row:hover {
        z-index: 2;
      }

      .rate-label, .rate-val {
        padding: 0.7rem 1.25rem;
        transition: background 0.15s ease, box-shadow 0.15s ease;
        position: relative;
      }
      .rates-row:hover .rate-label,
      .rates-row:hover .rate-val {
        background: var(--surface-2);
        box-shadow: var(--row-shadow);
        z-index: 2;
      }
      .rate-label {
        background: var(--bg);
        font-size: 0.8rem;
        color: var(--text-secondary);
      }
      .rate-val {
        background: var(--bg);
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        color: var(--text);
      }

      .limits-table-wrap { overflow-x: auto; max-width: 680px; margin: 0 auto; }

      .limits-table {
        width: 100%;
        border-collapse: collapse;
        border: 1px solid var(--border);
      }
      .limits-table th,
      .limits-table td {
        padding: 0.65rem 1.25rem;
        text-align: left;
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
      }
      .limits-table thead th {
        font-size: 0.625rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--text-muted);
        background: var(--surface);
      }
      .limits-table thead th:last-child { background: var(--surface-2); }
      .limits-table td:first-child {
        font-size: 0.8rem;
        color: var(--text-secondary);
        width: 50%;
        background: var(--bg);
      }
      .limits-table td:not(:first-child) {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.8rem;
        color: var(--text);
        background: var(--bg);
      }
      .limits-table td:last-child { background: var(--surface); }
      .limits-table tbody tr:last-child td { border-bottom: none; }
      .limits-table tbody tr {
        position: relative;
        z-index: 0;
      }
      .limits-table tbody tr:hover {
        z-index: 2;
      }
      .limits-table td {
        transition: background 0.15s ease, border-color 0.15s ease, box-shadow 0.15s ease;
        position: relative;
      }
      .limits-table tbody tr:hover td {
        background: var(--surface-2);
        border-color: var(--border-strong);
        z-index: 2;
        box-shadow: var(--row-shadow);
      }
      .limits-table tbody tr:hover td:last-child {
        background: var(--surface-2);
      }
      .rate-tag {
        display: inline-block;
        font-size: 0.575rem;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-muted);
        border: 1px solid var(--border-strong);
        padding: 0.1rem 0.35rem;
        vertical-align: middle;
        margin-left: 0.4rem;
      }

      .compute-examples {
        max-width: 680px;
        margin: -1px auto 3rem;
        border: 1px solid var(--border);
        border-top: none;
        display: flex;
        flex-direction: column;
        gap: 1px;
        background: var(--border);
      }

      .compute-example {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        padding: 0.55rem 1.25rem;
        background: var(--bg);
        gap: 1rem;
      }

      .compute-example-label {
        font-size: 0.775rem;
        color: var(--text-muted);
      }

      .compute-example-val {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.775rem;
        color: var(--text-secondary);
        white-space: nowrap;
      }

      .lim-check { color: var(--savings-text); font-weight: 600; }
      .lim-dash  { color: var(--text-muted); }

      /* ── PRODUCTS ── */

      .products {
        padding: clamp(4rem, 10vw, 7rem) clamp(1.5rem, 5vw, 4rem);
        border-bottom: 1px solid var(--border);
      }

      .products-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--border);
        border: 1px solid var(--border);
      }

      .product-card {
        background: var(--bg);
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 0;
        transition: background 0.15s;
        position: relative;
      }
      .product-card:hover { background: var(--surface); }

      .product-card-num {
        font-family: 'JetBrains Mono', monospace;
        font-size: 0.625rem;
        font-weight: 500;
        color: var(--text-muted);
        letter-spacing: 0.12em;
        margin-bottom: 1.75rem;
      }

      .product-card-icon {
        display: none;
      }

      .product-card h3 {
        font-size: 0.9375rem;
        font-weight: 600;
