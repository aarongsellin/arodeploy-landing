    <script>
      /* ── Region rotation ── */
      (() => {
        const regions = ['US', 'EU', 'Singapore'];
        const el = document.getElementById('region-rotate');
        if (!el) return;
        let idx = 0;
        setInterval(() => {
          el.style.opacity = '0';
          setTimeout(() => {
            idx = (idx + 1) % regions.length;
            el.textContent = regions[idx];
            el.style.opacity = '1';
          }, 500);
        }, 3000);
      })();

      /* ── Theme toggle ── */
      (() => {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', () => {
          const html = document.documentElement;
          const current = html.getAttribute('data-theme');
          let next;
          if (!current) {
            /* System default — toggle to the opposite */
            next = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'light' : 'dark';
          } else {
            next = current === 'dark' ? 'light' : 'dark';
          }
          html.setAttribute('data-theme', next);
          localStorage.setItem('arodeploy-theme', next);
        });
      })();

      /* ── Custom Tier Calculator ── */
      (() => {
        const serverSelect = document.getElementById('serverSelect');
        const dataSlider = document.getElementById('dataSlider') as HTMLInputElement | null;
        
        if (!serverSelect || !dataSlider) return;

        // Initialize with CPX31 selected
        let selectedServer = {
          vcpu: 4,
          ram: 16,
          ssd: 160,
          monthlyEur: 33.59,
        };

        function calculateDataFee(dataGb: number): number {
          if (dataGb === 0) return 0;
          
          // Tiers: 0-15TB included (€0), 15-30TB €2/TB, 30TB+ €1.50/TB
          const tier1MaxGb = 15 * 1024; // 15TB in GB
          const tier2MaxGb = 30 * 1024; // 30TB in GB

          let fee = 0;

          if (dataGb > tier1MaxGb) {
            // Data exceeds the included 15TB
            if (dataGb <= tier2MaxGb) {
              // All overage is in tier 2 (15-30TB range)
              const tbInTier2 = (dataGb - tier1MaxGb) / 1024;
              fee += tbInTier2 * 2; // €2 per TB
            } else {
              // Part in tier 2, part in tier 3
              const tbInTier2 = (tier2MaxGb - tier1MaxGb) / 1024; // 15TB
              fee += tbInTier2 * 2; // €2 × 15 = €30

              const tbInTier3 = (dataGb - tier2MaxGb) / 1024;
              fee += tbInTier3 * 1.5; // €1.50 per TB for anything over 30TB
            }
          }
          // If dataGb <= tier1MaxGb, data is included (fee = 0)

          return fee;
        }

        function updateDisplay() {
          const dataTb = parseInt(dataSlider!.value);
          const dataGb = dataTb * 1024;

          const dataAmountEl = document.getElementById('dataAmount');
          if (dataAmountEl) dataAmountEl.textContent = String(dataTb);
          
          const dataFee = calculateDataFee(dataGb);
          const totalPrice = selectedServer.monthlyEur + dataFee;

          const basePriceEl = document.getElementById('basePriceDisplay');
          const dataFeeEl = document.getElementById('dataFeeDisplay');
          const totalPriceEl = document.getElementById('totalPrice');

          if (basePriceEl) basePriceEl.textContent = selectedServer.monthlyEur.toFixed(2);
          if (dataFeeEl) dataFeeEl.textContent = dataFee.toFixed(2);
          if (totalPriceEl) totalPriceEl.textContent = totalPrice.toFixed(2);
        }

        // Server selection
        const serverButtons = serverSelect.querySelectorAll('.calc-server-btn') as NodeListOf<HTMLButtonElement>;
        serverButtons.forEach((btn) => {
          btn.addEventListener('click', () => {
            serverButtons.forEach((b) => b.classList.remove('selected'));
            btn.classList.add('selected');

            selectedServer = {
              vcpu: parseInt(btn.dataset.vcpu || '0'),
              ram: parseInt(btn.dataset.ram || '0'),
              ssd: parseInt(btn.dataset.ssd || '0'),
              monthlyEur: parseFloat(btn.dataset.monthlyEur || '0'),
            };

            updateDisplay();
          });
        });

        // Data slider
        dataSlider.addEventListener('input', updateDisplay);

        // Initial display update
        updateDisplay();
      })();
    </script>

  </body>
</html>
